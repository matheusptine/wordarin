      "grammar": [
        {
          "title": "Frase simples 1: sujeito + verbo (+ objecto)",
          "chineseTitle": "简单句型1：主语 + 动词（+ 宾语）",
          "content": "Semelhante a português, em chinês, a frase simples é constituída por: Sujeito + Verbo (+ Objecto)",
          "pattern": "Sujeito + Verbo + Objecto",
          "examples": [
            { "affirmative": "我姓王。Wǒ xìng Wáng.", "pt_aff": "O meu apelido é Wang.", "negative": "我不姓王。Wǒ bù xìng Wáng.", "pt_neg": "O meu apelido não é Wang." },
            { "affirmative": "我说法语。Wǒ shuō Fǎyǔ.", "pt_aff": "Eu falo francês.", "negative": "我不说法语。Wǒ bù shuō Fǎyǔ.", "pt_neg": "Eu não falo francês." },
            { "affirmative": "我们都是中国人。Wǒmen dōu shì Zhōngguórén.", "pt_aff": "Somos todos chineses.", "negative": "我们都不是中国人。Wǒmen dōu bù shì Zhōngguórén.", "pt_neg": "Nenhum de nós é chinês." }
          ]
        },
        {
          "title": "Advérbio + verbo",
          "chineseTitle": "副词 + 动词",
          "content": "Ao contrário do português, o advérbio em chinês aparece sempre antes do verbo.",
          "pattern": "Advérbio + Verbo",
          "examples": [
            { "affirmative": "他不是美国人。Tā bú shì Měiguórén.", "pt_aff": "Ele não é americano." },
            { "affirmative": "他也是美国人。Tā yě shì Měiguórén.", "pt_aff": "Ele também é americano." },
            { "affirmative": "他们都是美国人。Tāmen dōu shì Měiguórén.", "pt_aff": "Eles são todos americanos." },
            { "affirmative": "他只说汉语。Tā zhǐ shuō Hànyǔ.", "pt_aff": "Ele só fala chinês." }
          ]
        },
        {
          "title": "Frases interrogativas",
          "chineseTitle": "疑问句",
