      "texts": [
        {
          "number": "1",
          "context": "Bai Xiaohong, estudante chinesa, e Wang Ying, estudante canadiana de ascendência chinesa, são colegas da universidade. Éaqui o primeiro encontro delas.",
          "lines": [
            { "speaker": "白小虹", "pinyin": "Nín hǎo！", "hanzi": "您　好！", "pt": "Olá!" },
            { "speaker": "王英", "pinyin": "Nín hǎo！", "hanzi": "您　好！", "pt": "Olá!" },
            { "speaker": "白小虹", "pinyin": "Nín guìxìng？", "hanzi": "您贵姓？", "pt": "Qual é o seu apelido?" },
            { "speaker": "王英", "pinyin": "Wǒ xìng Wáng. Nín ne？", "hanzi": "我　姓　王。您呢？", "pt": "O meu apelido é Wang. E você?" },
            { "speaker": "白小虹", "pinyin": "Wǒ xìng Bái.", "hanzi": "我　姓　白。", "pt": "O meu apelido é Bai." },
            { "speaker": "王英", "pinyin": "Nín shì Kāsídǎorén ma？", "hanzi": "您是葡萄牙人吗？", "pt": "Você é portuguesa?" },
            { "speaker": "白小虹", "pinyin": "Bù, wǒ bú shì Kāsídǎorén. Wǒ shì Zhōngguórén. Nín shì bu shì Kāsídǎorén？", "hanzi": "不，我不是葡萄牙人，我是中国人。您是不是葡萄牙人？", "pt": "Não, eu não sou portuguesa, eu sou chinesa. Você é ou não é portuguesa?" },
            { "speaker": "王英", "pinyin": "Wǒ shì Jiānádàrén.", "hanzi": "我是加拿大人。", "pt": "Eu sou canadiana." }
          ]
        },
        {
          "number": "2",
          "context": "Na presença do professor Liu.",
          "lines": [
            { "speaker": "张老师", "pinyin": "Nǐ hǎo！Nǐ shì xuésheng ma？", "hanzi": "你　好！你是学生吗？", "pt": "Olá! Você é estudante?" },
            { "speaker": "同学甲", "pinyin": "Nín hǎo！Wǒ shì xuésheng. Wǒ shì lǎoshī ma？", "hanzi": "您　好！我是学生。您是老师吗？", "pt": "Olá! Eu sou estudante. O senhor é professor?" },
            { "speaker": "张老师", "pinyin": "Duì. Wǒ shì lǎoshī.", "hanzi": "对。我是老师。", "pt": "Sim. Eu sou professor." },
            { "speaker": "同学乙", "pinyin": "Nín hǎo！Nín shuō Yīngyǔ ma？", "hanzi": "您好！您说英语吗？", "pt": "Olá! O senhor fala inglês?" },
            { "speaker": "张老师", "pinyin": "Wǒ bù shuō Pútáoyáyǔ. Wǒ zhǐ shuō Hànyǔ.", "hanzi": "我不说葡萄牙语，我只说汉语。", "pt": "Eu não falo português. Eu só falo chinês." }
          ]
        }
